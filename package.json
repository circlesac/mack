{
  "author": "Circles Inc.",
  "dependencies": {
    "@slack/types": "^2.1.0",
    "fast-xml-parser": "^4.0.6",
    "marked": "^4.0.12"
  },
  "description": "Converts Markdown to Slack BlockKit Blocks",
  "devDependencies": {
    "@circlesac/lint": "^26.2.2",
    "@types/marked": "^4.0.2",
    "@types/node": "^15.12.4",
    "typescript": "^4.3.4",
    "vitest": "^3"
  },
  "keywords": [
    "markdown",
    "parser",
    "gfm",
    "slack"
  ],
  "license": "MIT",
  "main": "build/src/index.js",
